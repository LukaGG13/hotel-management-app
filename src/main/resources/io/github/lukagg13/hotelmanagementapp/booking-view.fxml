<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets left="10.0" right="10.0" />
    </padding>

    <fx:include source="header-view.fxml" />
    <HBox alignment="CENTER_LEFT" prefHeight="35.0" spacing="10.0">
        <children>
            <TextField fx:id="searchTextField" maxWidth="1.7976931348623157E308" prefHeight="35.0" promptText="Search..." HBox.hgrow="ALWAYS" />

            <Button fx:id="editBookingButton" mnemonicParsing="false" prefHeight="35.0" prefWidth="80.0" text="Edit" />
            <Button fx:id="deleteBookingButton" mnemonicParsing="false" prefHeight="35.0" prefWidth="80.0" text="Delete" />
        </children>
    </HBox>

    <TableView fx:id="bookingTable">
        <columns>
            <TableColumn fx:id="roomNumber" text="Room Number" />
            <TableColumn fx:id="checkIn" text="Check-In Date" />
            <TableColumn fx:id="checkOut" text="Check-Out Date" />
            <TableColumn fx:id="guestCount" text="Number of Guests" />
            <TableColumn fx:id="guestNames" text="guests" />
        </columns>
    </TableView>

    <Button prefHeight="35.0" fx:id="createBookingButton" text="Add Booking" />

</VBox>
