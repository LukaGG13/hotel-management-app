<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<fx:root type="javafx.scene.layout.VBox" spacing="5.0" style="-fx-border-color: #ccc; -fx-border-radius: 5; -fx-background-radius: 5;" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml">
    <children>
        <Label fx:id="nameLabel" style="-fx-font-weight: bold; -fx-font-size: 14px;" text="Name" />
        <Label fx:id="ageLabel" style="-fx-text-fill: #555;" text="Age: " />
    </children>
    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
    </padding>
</fx:root>
